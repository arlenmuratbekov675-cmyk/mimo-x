# Copy this file to .env and fill in values.
# .env is git-ignored and never committed.

APP_NAME=MiMo X
ENVIRONMENT=development

# SQLite for now. Switch to PostgreSQL later, e.g.:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/mimox
DATABASE_URL=sqlite:///./mimo_x.db

# API keys live on the SERVER only (never in the browser). Unused at Step 0.
TWELVEDATA_API_KEY=
FRED_API_KEY=
