APP_NAME=MiMo X
ENVIRONMENT=production
# DB lives on a mounted volume so it survives container rebuilds (needed for backtest history)
DATABASE_URL=sqlite:////data/mimo_x.db

# Data providers
TWELVEDATA_API_KEY=your_twelvedata_key_here
FRED_API_KEY=your_fred_key_here

# Step 5 caching (seconds) - avoids provider rate limits
CACHE_TTL_SECONDS=300

# Step 6 auth - if set, callers must send header  X-API-Key: <value>. Empty = open.
API_KEY=

# Step 7 backtest calibration
BACKTEST_MIN_SAMPLES=30
BACKTEST_HORIZON_HOURS=24
